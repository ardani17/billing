# ISPBoss production environment template
# Copy to a secure production secret store. Do not commit real values.

APP_ENV=production
LOG_LEVEL=info

DB_HOST=postgres.example.internal
DB_PORT=5432
DB_USER=ispboss
DB_PASSWORD=replace-with-strong-production-db-password
DB_NAME=ispboss
DB_SSL_MODE=require

REDIS_HOST=redis.example.internal
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-production-redis-password

JWT_SECRET=replace-with-random-minimum-32-character-secret
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=720h
CORS_ALLOW_ORIGINS=https://app.example.com,https://owner.example.com
GLOBAL_RATE_LIMIT_MAX=300
GLOBAL_RATE_LIMIT_WINDOW=1m

# Web/API proxy
BILLING_API_URL=https://api.example.com
ISPBOSS_ENABLE_DEV_AUTH=false

# Payment gateway
GATEWAY_MASTER_KEY=replace-with-64-hex-character-key
XENDIT_WEBHOOK_IPS=
MIDTRANS_WEBHOOK_IPS=
WEBHOOK_LOG_RETENTION_DAYS=90

# Billing safety defaults
ISOLIR_AUTOMATION_ENABLED=false
ISOLIR_PERIODIC_SYNC_ENABLED=false

# Optional add-on module service. Keep disabled unless purchased/enabled.
NETWORK_MODE=mock
ENCRYPTION_KEY=replace-with-64-hex-character-key
ROUTER_HEALTH_CHECK_ENABLED=false
PPPOE_SYNC_SCHEDULER_ENABLED=false
