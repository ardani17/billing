# =============================================================================
# ISPBoss Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local development.
# Required variables are marked with [REQUIRED].
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# [REQUIRED] Service name (billing-api, network-service, notification)
APP_NAME=billing-api

# [REQUIRED] HTTP port the service listens on
# billing-api: 3001, network-service: 3002, notification: 3003
APP_PORT=3001

# Application environment (development, staging, production)
APP_ENV=development

# Log level (debug, info, warn, error, fatal)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL host
DB_HOST=localhost

# PostgreSQL port
DB_PORT=5432

# [REQUIRED] PostgreSQL username
DB_USER=ispboss

# [REQUIRED] PostgreSQL password
DB_PASSWORD=ispboss_secret

# [REQUIRED] PostgreSQL database name
DB_NAME=ispboss

# PostgreSQL SSL mode (disable, require, verify-ca, verify-full)
DB_SSL_MODE=disable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# [REQUIRED] Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (leave empty if no auth)
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# [REQUIRED] Secret key for JWT token signing (use a strong random string)
JWT_SECRET=change-me-to-a-strong-secret

# JWT token expiry duration (Go duration format)
JWT_EXPIRY=24h

# -----------------------------------------------------------------------------
# Network Service
# -----------------------------------------------------------------------------

# Network service operation mode (mock or live)
# mock: simulated responses for development
# live: real MikroTik/OLT integration
NETWORK_MODE=mock
